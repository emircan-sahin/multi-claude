{
  "name": "multi-claude",
  "version": "1.0.0",
  "description": "Peer-to-peer messaging between Claude Code instances",
  "main": "dist/cli.js",
  "bin": {
    "multi-claude": "dist/cli.js"
  },
  "files": [
    "dist",
    "src/connect.py"
  ],
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "setup": "node dist/cli.js setup",
    "lint": "eslint src/",
    "test": "vitest run",
    "check": "npm run lint && tsc --noEmit && npm test",
    "start": "tsx src/orchestrator.ts",
    "connect": "python3 src/connect.py",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "multi-agent",
    "peer-to-peer",
    "ai-agents"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0"
  }
}
