{
  "name": "multi-claude",
  "version": "1.0.0",
  "description": "Peer-to-peer messaging between Claude Code instances",
  "main": "dist/cli.js",
  "bin": {
    "multi-claude": "dist/cli.js"
  },
  "files": [
    "dist",
    "src/connect.py"
  ],
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "setup": "node dist/cli.js setup",
    "start": "tsx src/orchestrator.ts",
    "connect": "python3 src/connect.py",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "multi-agent",
    "peer-to-peer",
    "ai-agents"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0"
  }
}
